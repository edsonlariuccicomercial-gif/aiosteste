{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.sheetjs.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://mvvsjaudhbglxttxaeop.supabase.co wss://mvvsjaudhbglxttxaeop.supabase.co https://api.caixaescolar.educacao.mg.gov.br; img-src 'self' data: blob:; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/sgd-proxy", "destination": "/api/caixa-proxy" },
    { "source": "/api/b2b-scrape", "destination": "/api/caixa-proxy" }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/squads/caixa-escolar/dashboard/gdp-contratos.html",
      "permanent": false
    },
    {
      "source": "/gdp-contratos.html",
      "destination": "/squads/caixa-escolar/dashboard/gdp-contratos.html",
      "permanent": false
    },
    {
      "source": "/gdp-estoque-intel-mobile.html",
      "destination": "/squads/caixa-escolar/dashboard/gdp-estoque-intel-mobile.html",
      "permanent": false
    }
  ],
  "functions": {
    "api/caixa-proxy.js": { "maxDuration": 60 },
    "api/ai-parse-price.js": { "maxDuration": 60 },
    "api/gdp-integrations.js": { "maxDuration": 60 },
    "api/bank-charge.js": { "maxDuration": 60 },
    "api/send-order-email.js": { "maxDuration": 60 }
  }
}
